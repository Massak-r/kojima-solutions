Options -MultiViews
RewriteEngine On

# ── PHP upload limits (belt-and-suspenders with api/.user.ini) ──
<IfModule mod_php.c>
  php_value upload_max_filesize 200M
  php_value post_max_size 210M
  php_value max_execution_time 300
  php_value max_input_time 300
  php_value memory_limit 256M
</IfModule>

# Prioritize index.html over any index.php
DirectoryIndex index.html index.php

# ── Favicon fallback (browsers request /favicon.ico for non-HTML pages like PDFs)
RewriteRule ^favicon\.ico$ /favicon.svg [L,T=image/svg+xml]

# ── Cache Control ─────────────────────────────────────────────
<IfModule mod_headers.c>
  # Service worker & manifest: always revalidate
  <FilesMatch "(sw\.js|manifest\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Vite-hashed assets: immutable cache (1 year)
  <FilesMatch "\.(js|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # API responses: no store
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store"
  </FilesMatch>
</IfModule>

# ── React Router SPA fallback ─────────────────────────────────
# FallbackResource serves index.html for any URL that doesn't
# match a real file or directory (works without mod_rewrite).
FallbackResource /index.html
